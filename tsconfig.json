{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "app",
    "src",
    "tests",
    "*.d.ts",
    "babel.config.js",
    "eslint.config.js",
    "jest.config.ts",
    "metro.config.js",
    "tailwind.config.js",
    "nativewind-env.d.ts"
  ]
}
# Mobile API base URL. Expo inlines EXPO_PUBLIC_* variables at build time.
#
# Local backend (default):   http://localhost:3000
# Physical device on LAN:    http://<your-machine-LAN-IP>:3000  (e.g. http://192.168.1.50:3000)
# Dev / production-demo:      set to the deployed backend URL (see README).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

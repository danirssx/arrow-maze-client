{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Client uses jest-expo (babel). Mutation focuses on pure game rules in domain/application. svg + reanimated stay mocked via __mocks__. See docs/mutation-testing.md.",
  "packageManager": "npm",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.ts",
    "enableFindRelatedTests": true
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/domain/**/*.{ts,tsx}",
    "src/application/**/*.{ts,tsx}",
    "!src/**/*.d.ts",
    "!src/**/index.ts",
    "!src/**/errors.ts",
    "!src/**/I*.ts"
  ],
  "ignorePatterns": ["dist", "coverage", "reports", ".stryker-tmp", ".expo"],
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": { "fileName": "reports/mutation/index.html" },
  "thresholds": { "high": 90, "low": 80, "break": 80 },
  "concurrency": 4,
  "timeoutMS": 60000
}
